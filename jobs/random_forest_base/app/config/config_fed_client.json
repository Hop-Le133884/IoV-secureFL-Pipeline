{
  "format_version": 2,
  "executors": [
    {
      "tasks": ["train_inner", "train_outer"],
      "executor": {
        "id": "Executor",
        "path": "iov_executor.DoubleRFExecutor",
        "args": {
          "data_loader_id": "dataloader",
          "nthread": 4,
          "dp_epsilon": null,
          "dp_delta": 1e-5,
          "dp_clip_bound": 5.0,
          "seed": 42
        }
      }
    }
  ],
  "components": [
    {
      "id": "dataloader",
      "path": "iov_data_loader.IoVDataLoader",
      "args": {
        "data_split_filename": "data_split.json"
      }
    }
  ]
}