# This files help to run all .py in one commands, and save logs to /logs/
server:   python src/federated/server.py > logs/server.log 2>&1
client0:  python src/federated/client.py --node-id 0 > logs/client-0.log 2>&1
client1:  python src/federated/client.py --node-id 1 > logs/client-1.log 2>&1
client2:  python src/federated/client.py --node-id 2 > logs/client-2.log 2>&1
client3:  python src/federated/client.py --node-id 3 > logs/client-3.log 2>&1
client4:  python src/federated/client.py --node-id 4 > logs/client-4.log 2>&1